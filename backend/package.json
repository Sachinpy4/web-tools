{
  "name": "web-tools-backend",
  "version": "1.0.0",
  "description": "NestJS backend for web tools - migrated from Express.js",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node --expose-gc --max-old-space-size=8192 --incremental-marking dist/main",
    "start:all": "concurrently \"npm run start:prod\" \"npm run worker\"",
    "start:all:dev": "concurrently \"npm run start:dev\" \"npm run worker:dev\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "worker": "node dist/worker",
    "worker:dev": "ts-node src/worker.ts",
    "worker:prod": "node --expose-gc dist/worker",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "deploy:build": "npm run build && mkdir -p logs",
    "deploy:docker": "docker-compose -f ../docker-compose.prod.yml up -d",
    "deploy:docker:build": "docker-compose -f ../docker-compose.prod.yml up --build -d",
    "setup:admin": "npm run build && node dist/scripts/setup-admin",
    "setup:admin:dev": "ts-node src/scripts/setup-admin.ts",
    "setup:admin:env": "npm run build && node dist/scripts/create-admin-env",
    "setup:admin:env:dev": "ts-node src/scripts/create-admin-env.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.15",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.15",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "archiver": "^7.0.1",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.70.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exifr": "^7.1.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "isomorphic-dompurify": "^3.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.2.3",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "opossum": "^8.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "validator": "^13.15.15",
    "winston": "^3.17.0"
  },
  "overrides": {
    "tar": ">=7.5.10",
    "lodash": ">=4.17.23",
    "braces": ">=3.0.3",
    "cookie": ">=0.7.0",
    "semver": ">=7.5.4",
    "glob": ">=10.4.0",
    "rimraf": ">=5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.15",
    "@types/archiver": "^6.0.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/opossum": "^8.1.8",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.15.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.56.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
